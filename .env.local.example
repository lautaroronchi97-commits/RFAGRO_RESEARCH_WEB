# ==========================================================================
# Plantilla de variables de entorno. COPIALA como `.env.local` (que git IGNORA)
# y completá los valores reales SOLO ahí y en Vercel (Settings > Environment
# Variables). NUNCA pongas credenciales reales en este archivo ni en el código.
# ==========================================================================

# A3 / Cocos xOMS (API Primary de trading). Base de la API del broker.
A3_API_BASE=https://api.cocos.xoms.com.ar

# Usuario y contraseña de tu cuenta de broker (los cargás vos en Vercel/.env.local).
A3_USERNAME=
A3_PASSWORD=

# Supabase (Postgres con los datos históricos: DJVE, lineups, compras, etc.).
# La URL y la clave publishable son PÚBLICAS por diseño (las tablas están
# protegidas por RLS de solo-lectura), pero igual van solo en .env.local y en
# Vercel > Environment Variables. Proyecto Supabase: lineup-argentina.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Clave publishable (formato sb_publishable_...), rol anónimo de solo lectura.
SUPABASE_ANON_KEY=
