# ==========================================================================
# Plantilla de variables de entorno. COPIALA como `.env.local` (que git IGNORA)
# y completá los valores reales SOLO ahí y en Vercel (Settings > Environment
# Variables). NUNCA pongas credenciales reales en este archivo ni en el código.
# ==========================================================================

# A3 / Cocos xOMS (API Primary de trading). Base de la API del broker.
A3_API_BASE=https://api.cocos.xoms.com.ar

# Usuario y contraseña de tu cuenta de broker (los cargás vos en Vercel/.env.local).
A3_USERNAME=
A3_PASSWORD=

# Supabase (Postgres con los datos históricos: DJVE, lineups, compras, etc.).
# La URL y la clave publishable son PÚBLICAS por diseño (las tablas están
# protegidas por RLS de solo-lectura), pero igual van solo en .env.local y en
# Vercel > Environment Variables. Proyecto Supabase: lineup-argentina.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Clave publishable (formato sb_publishable_...), rol anónimo de solo lectura.
SUPABASE_ANON_KEY=
# Clave service_role (ESCRITURA). SECRETA de verdad: SOLO para los jobs de ingesta
# (scripts/ + GitHub Actions), NUNCA en la web ni en el repo. Supabase > Settings > API.
SUPABASE_SERVICE_KEY=

# --------------------------------------------------------------------------
# LOGIN / Supabase Auth (ver docs/PLAN_LOGIN.md y docs/GUIA_LOGIN_SETUP.md).
# El SDK de Auth corre también en el navegador → necesita el prefijo NEXT_PUBLIC_.
# Son las MISMAS credenciales que arriba (URL + clave publishable/anon), solo con
# otro nombre; son públicas por diseño (RLS protege las filas).
# --------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Interruptor del login. APAGADO por defecto: la web sigue pública como hoy.
# Poné "true" (en Vercel) SOLO cuando hayas probado todo el flujo y quieras cerrar
# la web detrás del login. Cualquier otro valor (o vacío) = login apagado.
AUTH_ENFORCED=false

# URL pública del sitio, para los enlaces de los emails de Supabase (confirmación de
# cuenta, recupero de contraseña) y el callback de OAuth. En local podés dejarla vacía
# (se infiere del host). En Vercel: https://rfagro-research-web.vercel.app
NEXT_PUBLIC_SITE_URL=
